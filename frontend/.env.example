# Backend API base URL.
# IMPORTANT: This is a BUILD-TIME variable — Vite bakes it into the JS bundle.
# You cannot change it at runtime without rebuilding the frontend.
#
# For local dev without Docker, leave unset (defaults to http://localhost:8000).
# For Docker / production deployments, set this to your backend's public URL.
#
# Example: VITE_API_URL=https://api.yourdomain.com
VITE_API_URL=http://localhost:8000
